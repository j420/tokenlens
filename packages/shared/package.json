{
  "name": "@prune/shared",
  "version": "0.1.0",
  "description": "Shared types and utilities for Prune",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node-utils.d.ts",
      "import": "./dist/node-utils.js",
      "require": "./dist/node-utils.js",
      "default": "./dist/node-utils.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "vitest": "^2.1.0"
  }
}
