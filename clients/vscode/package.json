{
  "name": "prune",
  "displayName": "Prune - AI Token Intelligence",
  "description": "Real-time cost tracking and waste alerts for AI coding tools",
  "version": "0.1.0",
  "publisher": "delimit",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Prune",
      "properties": {
        "prune.apiKey": {
          "type": "string",
          "default": "",
          "description": "Your Prune API key (starts with prune_sk_)"
        },
        "prune.apiUrl": {
          "type": "string",
          "default": "wss://delimit.dev/api/v1/stream",
          "description": "Prune WebSocket stream URL"
        },
        "prune.thresholdAmber": {
          "type": "number",
          "default": 2,
          "description": "Session cost threshold for amber status ($)"
        },
        "prune.thresholdRed": {
          "type": "number",
          "default": 5,
          "description": "Session cost threshold for red status ($)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "ws": "^8.16.0"
  }
}
