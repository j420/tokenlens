# ===========================================
# PRUNE DASHBOARD - ENVIRONMENT VARIABLES
# ===========================================

# ----------------------------------------
# MINIMAL SETUP (works without database)
# ----------------------------------------
# The dashboard works out of the box with in-memory storage.
# No environment variables are required for basic functionality.

# ----------------------------------------
# PRODUCTION SETUP (Vercel KV for persistence)
# ----------------------------------------
# For persistent storage, add Vercel KV:
# Vercel Dashboard → Storage → Create → KV
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ----------------------------------------
# FULL SETUP (with authentication)
# ----------------------------------------
# Database (Vercel Postgres)
# Vercel Dashboard → Storage → Create → Postgres
DATABASE_URL=

# NextAuth.js (for user authentication)
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://your-app.vercel.app

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ----------------------------------------
# OPTIONAL INTEGRATIONS
# ----------------------------------------
# Upstash Redis (alternative to Vercel KV)
REDIS_URL=

# Slack alerts for team notifications
SLACK_WEBHOOK_URL=

# ===========================================
# VERCEL DEPLOYMENT INSTRUCTIONS
# ===========================================
#
# 1. Push this repo to GitHub
#
# 2. Import to Vercel:
#    - Go to vercel.com/new
#    - Import your GitHub repo
#    - Set "Root Directory" to: apps/dashboard
#    - Framework Preset: Next.js (auto-detected)
#    - Click Deploy
#
# 3. (Optional) Add storage for persistence:
#    - Vercel Dashboard → Your Project → Storage
#    - Create KV store and link to project
#    - Environment variables are auto-added
#
# 4. (Optional) Add Postgres for full features:
#    - Vercel Dashboard → Storage → Create Postgres
#    - Run migrations: npm run db:push
#
# The dashboard works without any storage configured.
# Events will be stored in-memory (resets on redeploy).
# ===========================================
