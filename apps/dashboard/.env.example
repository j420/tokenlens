# ===========================================
# PRUNE DASHBOARD - VERCEL ENVIRONMENT VARIABLES
# ===========================================

# Database (Vercel Postgres recommended)
# Get this from: Vercel Dashboard → Storage → Postgres
DATABASE_URL=postgres://user:password@host:5432/prune

# Redis/KV for caching (Vercel KV or Upstash recommended)
# Option 1: Vercel KV (preferred)
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Option 2: Upstash Redis
REDIS_URL=redis://default:password@host:6379

# NextAuth.js Configuration
# Generate secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=https://your-domain.vercel.app

# OAuth providers (optional - for GitHub login)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Slack integration for team alerts (optional)
SLACK_WEBHOOK_URL=

# Application settings
NODE_ENV=production

# ===========================================
# NOTES FOR VERCEL DEPLOYMENT
# ===========================================
# 1. Set all required variables in Vercel Dashboard → Settings → Environment Variables
# 2. Required for basic functionality: DATABASE_URL, NEXTAUTH_SECRET, NEXTAUTH_URL
# 3. The proxy endpoints (api/v1/proxy/*) pass through API keys from requests
#    - Users provide their own ANTHROPIC_API_KEY or OPENAI_API_KEY via headers
#    - The proxy does NOT require these keys to be set server-side
# 4. For Vercel Postgres, use the connection string from the Vercel dashboard
# 5. For production, ensure NEXTAUTH_URL matches your Vercel deployment URL
