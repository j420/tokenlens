{
  "name": "prune",
  "displayName": "Prune - Token Intelligence",
  "description": "Real-time AI token counting for VS Code. See token costs as you code.",
  "version": "0.1.0",
  "publisher": "delimit",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Machine Learning",
    "Programming Languages"
  ],
  "keywords": [
    "ai",
    "tokens",
    "cursor",
    "claude",
    "gpt",
    "cost",
    "optimization"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "prune.analyzeSelection",
        "title": "Prune: Analyze Token Count"
      },
      {
        "command": "prune.analyzeFile",
        "title": "Prune: Analyze Current File"
      },
      {
        "command": "prune.copyTokenCount",
        "title": "Prune: Copy Token Count"
      },
      {
        "command": "prune.squeezeFile",
        "title": "Prune: Squeeze File (Compress for AI)"
      },
      {
        "command": "prune.checkCursorUsage",
        "title": "Prune: Check Cursor Usage"
      }
    ],
    "configuration": {
      "title": "Prune",
      "properties": {
        "prune.autoSqueezeThreshold": {
          "type": "number",
          "default": 10000,
          "description": "Token count above which to show warning"
        },
        "prune.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show token count in status bar"
        }
      }
    },
    "menus": {
      "editor/context": [
        {
          "command": "prune.analyzeSelection",
          "group": "prune",
          "when": "editorHasSelection"
        },
        {
          "command": "prune.copyTokenCount",
          "group": "prune"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "npm run build -- --watch",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@prune/tokenizer": "0.1.0",
    "@prune/shared": "0.1.0",
    "@prune/squeezer": "0.1.0",
    "@prune/state-scraper": "0.1.0",
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.10.0",
    "esbuild": "^0.19.11",
    "typescript": "^5.3.3",
    "@vscode/vsce": "^2.22.0"
  }
}
