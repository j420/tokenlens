{
  "name": "prune",
  "displayName": "Prune - Token Intelligence",
  "description": "Reduce AI token costs with intelligent context compression. Zero API keys required.",
  "version": "0.1.0",
  "publisher": "delimit",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Machine Learning",
    "Programming Languages"
  ],
  "keywords": [
    "ai",
    "tokens",
    "cursor",
    "claude",
    "gpt",
    "cost",
    "optimization"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "prune.analyzeSelection",
        "title": "Prune: Analyze Selection"
      },
      {
        "command": "prune.squeezeSelection",
        "title": "Prune: Squeeze Selection"
      },
      {
        "command": "prune.squeezeFile",
        "title": "Prune: Squeeze Current File"
      },
      {
        "command": "prune.showDiff",
        "title": "Prune: Show Squeeze Diff"
      },
      {
        "command": "prune.checkUsage",
        "title": "Prune: Check Usage"
      }
    ],
    "configuration": {
      "title": "Prune",
      "properties": {
        "prune.defaultTier": {
          "type": "string",
          "default": "structural",
          "enum": ["lossless", "structural", "telegraphic"],
          "description": "Default compression tier"
        },
        "prune.autoSqueezeThreshold": {
          "type": "number",
          "default": 10000,
          "description": "Token count above which to suggest squeezing"
        },
        "prune.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show token count in status bar"
        },
        "prune.showPreflightWarnings": {
          "type": "boolean",
          "default": true,
          "description": "Show warnings before large context operations"
        },
        "prune.preserveTodos": {
          "type": "boolean",
          "default": true,
          "description": "Preserve TODO comments during compression"
        },
        "prune.preserveTypeHints": {
          "type": "boolean",
          "default": true,
          "description": "Preserve type hints and annotations"
        }
      }
    },
    "menus": {
      "editor/context": [
        {
          "command": "prune.analyzeSelection",
          "group": "prune",
          "when": "editorHasSelection"
        },
        {
          "command": "prune.squeezeSelection",
          "group": "prune",
          "when": "editorHasSelection"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "npm run build -- --watch",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "dependencies": {
    "@prune/tokenizer": "0.1.0",
    "@prune/squeezer": "0.1.0",
    "@prune/state-scraper": "0.1.0",
    "@prune/shared": "0.1.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.10.0",
    "esbuild": "^0.19.11",
    "typescript": "^5.3.3",
    "@vscode/vsce": "^2.22.0"
  }
}
